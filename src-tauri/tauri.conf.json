{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Claude Monitor",
	"version": "0.1.0",
	"identifier": "com.claude-monitor.app",
	"build": {
		"frontendDist": "../src"
	},
	"app": {
		"withGlobalTauri": true,
		"windows": [
			{
				"label": "panel",
				"title": "Claude Monitor",
				"width": 340,
				"height": 520,
				"visible": false,
				"decorations": false,
				"skipTaskbar": true,
				"alwaysOnTop": true,
				"resizable": false,
				"transparent": true
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
